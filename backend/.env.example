# ==========================================
# TALÉ HOTEL — backend/.env
# Copy to `.env` and fill in real values.
# DO NOT commit the real .env file.
# ==========================================

# 0. Environment
NODE_ENV=development
# Port the API listens on. In production the single VPS usually keeps 5000
# (Nginx reverse-proxies /api/* to 127.0.0.1:5000).
PORT=5000
# Bind address. 127.0.0.1 in dev; 0.0.0.0 or 127.0.0.1 in prod (PM2/systemd).
# BIND_HOST=127.0.0.1

# 1. MongoDB
# Dev (local): mongodb://127.0.0.1:27017/tale
# VPS (self-hosted on the same box): mongodb://127.0.0.1:27017/tale_hotel
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/tale_hotel?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/tale

# 2. Auth
# Generate a fresh random string for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_48_byte_random_hex

# 3. CORS (REQUIRED in production)
# Comma-separated list of allowed origins for the browser. In dev the backend
# defaults to http://localhost:3000; in production you MUST set this to your
# real frontend origin(s).
# CORS_ORIGIN=https://talehotel.com,https://www.talehotel.com

# 4. Reverse proxy (VPS)
# Keep 1 (single hop through Nginx). Set to false for a direct public listener.
# TRUST_PROXY=1

# 5. Cloudinary (admin image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 6. PayMob (UNDER DEVELOPMENT — flip enabled only when production-ready)
PAYMOB_ENABLED=false
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
HMAC_SECRET=

# 7. Google / Facebook OAuth (optional, guest sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 8. Outbound email (Gmail SMTP via Nodemailer)
# Use a Gmail App Password (Account → Security → App passwords), NOT your login.
EMAIL_USER=you@gmail.com
EMAIL_PASS=app_password_with_spaces

# 9. Lead notifications
# Optional; falls back to EMAIL_USER. Where new presentation requests are mailed.
# LEADS_INBOX=sales@talehotel.com
# When the lead replies to the auto-reply, which address should receive it?
# LEADS_REPLY_TO=sales@talehotel.com
# Set to "false" to disable the guest auto-reply.
# LEADS_AUTOREPLY=true

# 10. Lead rate limiting (POST /api/leads)
# LEAD_RATE_WINDOW_MS=900000
# LEAD_RATE_MAX=5

# 11. Global booking pause (optional)
# Omit or leave empty — guests can submit reservation requests normally.
# When set (YYYY-MM-DD or ISO instant), reservation requests are blocked until that UTC time.
BOOKING_OPENS_AT=

# 12. Dev-only admin bootstrap (ignored when NODE_ENV=production)
# If your database has no Admin yet, the server creates one from these the
# first time it starts. Delete after you've logged in once.
# ADMIN_BOOTSTRAP_EMAIL=admin@talehotel.com
# ADMIN_BOOTSTRAP_PASSWORD=change_me_now
