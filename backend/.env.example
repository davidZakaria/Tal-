# ==========================================
# TALÉ HOTEL SECURE ENVIRONMENT VARIABLES
# Rename this file to `.env` and fill it out
# ==========================================

# 1. MongoDB Database (local default uses 127.0.0.1 to match the API bind host)
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/tale?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/tale

# Optional: if port 5000 is busy — also set frontend BACKEND_URL / NEXT_PUBLIC_API_URL accordingly
# PORT=5001
# BIND_HOST=127.0.0.1

# 2. Authentication Tokens
JWT_SECRET=super_secret_jwt_key_tale_123

# 3. Cloudinary (signed uploads from admin — required for property images)
# Dashboard: https://console.cloudinary.com → Settings → Product environment credentials
# Cloud name is one word (often like dxxxx or my-cloud); NOT your display name — no spaces.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 4. PayMob API (Checkout Integration)
PAYMOB_API_KEY=your_paymob_key
HMAC_SECRET=your_paymob_hmac
